# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_PORT=3000

# ── Backend ───────────────────────────────────────────────────────────────────
BACKEND_EXTERNAL_PORT=8002

# Host IP returned in pre-signed MinIO URLs (use your LAN IP when on a VM)
PORTAL_BACKEND_HOST_IP=localhost

# URL scheme for pre-signed URLs ("https" | "" for http)
EXTERNAL_SCHEME=

# Whether to use SSL termination inside the container
USE_SSL=false

# Nginx route prefix injected into the plugin (keep default unless deployed via portal)
PLUGIN_ROUTE_PREFIX=/plugin/medical-image-annotator

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_SERVER_ACCESS_KEY=minioadmin
MINIO_SERVER_SECRET_KEY=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
